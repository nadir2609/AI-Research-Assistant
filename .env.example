# Copy this to .env and fill in real values. DO NOT commit .env.

# --- LLM (for synthesis) ---
LLM_PROVIDER=anthropic        # anthropic | openai | gemini
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Web search provider ---
WEB_SEARCH_PROVIDER=tavily    # tavily | serper | duckduckgo
TAVILY_API_KEY=               # https://tavily.com — free 1000 req/month
# SERPER_API_KEY=             # https://serper.dev — free 2500 req
# (DuckDuckGo needs no key but the duckduckgo-search package must be installed.)

# --- SE-layer settings (you will populate these) ---
LOG_LEVEL=INFO
CACHE_DIR=./.cache
CACHE_TTL_SECONDS=86400
PER_SOURCE_TIMEOUT_SECONDS=10
MAX_SOURCES_PER_QUERY=3
